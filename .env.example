# Copy this file to .env on the home server and fill in real values.
# Do not commit .env.

# LLM / embedding APIs
UPSTAGE_API_KEY=your_upstage_api_key
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_this_password
NEO4J_URI=bolt://localhost:7687

# Local stores
CHROMA_PERSIST_DIR=./chroma_db

# Web ports
FRONTEND_PORT=80
BACKEND_PORT=8000
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Admin-only full sync from the Settings page.
# Use a long random value and do not expose it publicly.
SYNC_ADMIN_TOKEN=change_this_sync_token
MAX_SYNC_PAGES=5

# Comma-separated allowed origins for direct backend access.
# If users access through the frontend nginx on the same host, this is mostly a fallback.
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://YOUR_HOME_SERVER_IP

# Optional runtime toggles
USE_BM25_HYBRID=1
USE_RERANK=1
USE_GRAPH_GATING=1
GRAPH_USAGE=anchored
